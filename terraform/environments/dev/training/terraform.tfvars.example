aws_region                  = "us-east-1"
project_name                = "whatson"
environment                 = "dev"
existing_vpc_id             = "vpc-xxxxxxxxxxxxxxxxx"
existing_subnet_id          = "subnet-xxxxxxxxxxxxxxxxx"
existing_security_group_ids = ["sg-xxxxxxxxxxxxxxxxx"]
data_lake_bucket_name       = "project1-01-virg-whatson-dev-training-data-example"
duplicate_guard_table_name  = "whatson-dev-crawl-duplicate-guard"
crawl_dlq_name              = "whatson-dev-crawl-dlq"
crawl_dlq_arn               = "arn:aws:sqs:us-east-1:123456789012:whatson-dev-crawl-dlq"
training_instance_type      = "g4dn.xlarge"
training_runner_instance_profile_name = "whatson-dev-training-runner-profile"
crawl_lambda_role_arn              = "arn:aws:iam::123456789012:role/whatson-dev-crawl-role"
preprocess_lambda_role_arn         = "arn:aws:iam::123456789012:role/whatson-dev-preprocess-role"
falsify_news_lambda_role_arn       = "arn:aws:iam::123456789012:role/whatson-dev-falsify-news-role"

crawl_schedule_expression = "rate(6 hours)"

training_entrypoint = <<-EOT
echo "Starting placeholder training bootstrap"
echo "Dataset prefix: $${DATASET_PREFIX:-dataset}"
echo "Checkpoint prefix: $${CHECKPOINT_PREFIX:-model-artifact/checkpoints}"
EOT

training_environment_variables = {
  HF_HOME            = "/opt/whatson-training/.cache/huggingface"
  WANDB_DISABLED     = "true"
  TRAINING_IMAGE_REF = "future-runpod-compatible-image"
}
